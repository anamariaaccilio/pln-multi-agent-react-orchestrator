# Copia este archivo como ".env" (en la raiz del repo) y completa tu API key.
# .env esta en .gitignore: nunca se sube al repositorio.

GOOGLE_API_KEY=tu_api_key_de_google_ai_studio

# Opcional: varias API keys (una por cuenta personal del equipo), separadas
# por coma, para que evaluation/run_batch.py rote automaticamente entre
# ellas cuando una se queda sin cuota (free tier: 20 requests/dia/key).
# Si esta seteado, tiene prioridad sobre GOOGLE_API_KEY.
# GOOGLE_API_KEYS=key_persona_a,key_persona_b,key_persona_c

# Opcional: si en algun momento usan OpenRouter/Nemotron en vez de Gemini.
# OPENROUTER_API_KEY=
# NEMOTRON_CHAT_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
